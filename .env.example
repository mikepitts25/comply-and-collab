# --- Database (PostgreSQL) ---
# For local dev with docker-compose, this points at the bundled postgres service.
DATABASE_URL="postgresql://comply:comply@localhost:5432/comply?schema=public"

# --- Auth ---
# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
# MUST be overridden in any real/air-gapped deployment.
AUTH_SECRET="dev-only-change-me-please-generate-a-real-secret"

# Session lifetime in hours
SESSION_TTL_HOURS="12"
