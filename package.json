{
  "name": "comply-and-collab",
  "version": "0.1.0",
  "private": true,
  "description": "Collaborative cyber compliance platform for RMF/ATO, ACAS & STIG findings, POA&Ms, and mitigation tracking.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "build:catalog": "tsx scripts/build-catalog.ts",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.1.0",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.1",
    "exceljs": "4.4.0",
    "fast-xml-parser": "4.5.1",
    "jose": "5.9.6",
    "lucide-react": "0.469.0",
    "next": "15.5.4",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "prisma": "6.1.0",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "vitest": "^2.1.8"
  }
}
