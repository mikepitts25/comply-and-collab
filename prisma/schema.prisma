// Comply & Collab — data model
// Domain: RMF/ATO lifecycle, ACAS + STIG findings, POA&Ms, mitigation reuse.
// Designed for air-gapped PostgreSQL deployments.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// People & access
// ---------------------------------------------------------------------------

enum Role {
  ADMIN // app administrator
  ISSM // Information System Security Manager
  ISSO // Information System Security Officer
  ANALYST // compliance / security control assessor
  ENGINEER // system / DevOps engineer remediating findings
  AUDITOR // read-only oversight
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(ANALYST)
  active       Boolean  @default(true)
  // DoD EDIPI (10-digit) parsed from a CAC/PIV certificate subject CN, used to
  // map a client-cert identity (supplied by a trusted reverse proxy) to a user.
  edipi        String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  scanImports          ScanImport[]
  poamsOwned           Poam[]               @relation("PoamOwner")
  comments             Comment[]
  mitigationStatements MitigationStatement[]
  activities           Activity[]
  findingAssignments   Finding[]            @relation("FindingAssignee")
  apiKeys              ApiKey[]
  riskAcceptances      RiskAcceptance[]
  deviationsRequested  Deviation[]           @relation("DeviationRequestor")
  deviationsDecided    Deviation[]           @relation("DeviationDecider")
  evidenceUploads      Evidence[]
  documentsCreated     SystemDocument[]      @relation("DocumentCreator")
  documentsToReview    SystemDocument[]      @relation("DocumentReviewer")
  documentVersions     DocumentVersion[]
  documentEvents       DocumentEvent[]
}

// API key for programmatic / automated scan ingestion. The plaintext key is
// shown once at creation; only its SHA-256 hash is stored. Actions run as the
// owning user, so the user's role/capabilities apply.
model ApiKey {
  id         String    @id @default(cuid())
  name       String
  prefix     String // leading chars, for identification in the UI
  hash       String    @unique // sha256 of the full key
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  revokedAt  DateTime?

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Systems, boundaries & assets
// ---------------------------------------------------------------------------

enum ImpactLevel {
  LOW
  MODERATE
  HIGH
}

enum AuthorizationStatus {
  NOT_STARTED
  IN_PROGRESS
  ATO // Authorization to Operate
  ATO_WITH_CONDITIONS
  IATT // Interim Authority to Test
  DENIED // Denial of ATO
  EXPIRED
  DECOMMISSIONED
}

enum Framework {
  RMF_800_53 // NIST RMF / 800-53
  STIG // DISA STIG / SRG
  CMMC // CMMC 2.0 / 800-171
  FEDRAMP // FedRAMP
}

model System {
  id          String  @id @default(cuid())
  name        String
  acronym     String  @unique
  description String?

  // FIPS 199 categorization
  confidentiality ImpactLevel @default(MODERATE)
  integrity       ImpactLevel @default(MODERATE)
  availability    ImpactLevel @default(MODERATE)
  // Overall categorization (high-water mark)
  categorization  ImpactLevel @default(MODERATE)

  frameworks Framework[] @default([RMF_800_53, STIG])

  // ATO lifecycle
  authorizationStatus AuthorizationStatus @default(IN_PROGRESS)
  atoDate             DateTime?
  atoExpiration       DateTime?
  authorizingOfficial String?

  // A common control provider (e.g. an enclave / hosting environment) offers
  // its implemented controls for inheritance by subscribing systems.
  isCommonControlProvider Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets      Asset[]
  findings    Finding[]
  poams       Poam[]
  scanImports ScanImport[]
  controls    SystemControl[]
  snapshots   PostureSnapshot[]
  ppsm        PpsmEntry[]
  interconnections Interconnection[]
  documents   SystemDocument[]
}

enum AssetType {
  SERVER
  WORKSTATION
  NETWORK_DEVICE
  APPLIANCE
  DATABASE
  APPLICATION
  CONTAINER
  CLOUD_RESOURCE
  OTHER
}

model Asset {
  id       String    @id @default(cuid())
  system   System    @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId String
  hostname String
  fqdn     String?
  ipAddress String?
  macAddress String?
  osName   String?
  osVersion String?
  type     AssetType @default(SERVER)
  notes    String?

  // Hardware inventory detail (for the system hardware list / ATO package)
  manufacturer String?
  model        String?
  serialNumber String?
  location     String?
  virtual      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  findings Finding[]
  software SoftwareComponent[]

  @@unique([systemId, hostname])
  @@index([systemId])
}

enum SoftwareType {
  OPERATING_SYSTEM
  APPLICATION
  DATABASE
  MIDDLEWARE
  DRIVER
  FIRMWARE
  OTHER
}

// Per-asset software inventory entry (system software list).
model SoftwareComponent {
  id      String       @id @default(cuid())
  asset   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  assetId String
  name    String
  version String?
  vendor  String?
  type    SoftwareType @default(APPLICATION)
  eol     DateTime? // end-of-life / end-of-support date
  notes   String?

  createdAt DateTime @default(now())

  @@index([assetId])
}

enum Protocol {
  TCP
  UDP
  ICMP
  OTHER
}

enum FlowDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

enum PpsmStatus {
  APPROVED
  PENDING
  DENIED
}

// Ports, Protocols, and Services Management (PPSM) registration entry.
model PpsmEntry {
  id        String        @id @default(cuid())
  system    System        @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId  String
  port      String // single port or range, e.g. "443" or "8080-8090"
  protocol  Protocol      @default(TCP)
  service   String
  direction FlowDirection @default(INBOUND)
  boundary  String? // boundary crossed, e.g. "Enclave / IL5 boundary"
  dataDescription String?
  classification  String? // e.g. "CUI", "Unclassified"
  status    PpsmStatus    @default(PENDING)
  justification String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([systemId])
}

// ---------------------------------------------------------------------------
// Control catalog (NIST 800-53) + CCI mapping
// ---------------------------------------------------------------------------

model Control {
  id       String  @id // e.g. "AC-2"
  family   String // e.g. "AC"
  title    String
  text     String? @db.Text
  // Baselines this control belongs to
  baselineLow      Boolean @default(false)
  baselineModerate Boolean @default(false)
  baselineHigh     Boolean @default(false)

  ccis           Cci[]
  systemControls SystemControl[]
  findingLinks   FindingControl[]
  poamLinks      PoamControl[]
  mitigationLinks MitigationControl[]

  @@index([family])
}

// Control Correlation Identifier — the bridge between STIG rules and 800-53.
model Cci {
  id         String  @id // e.g. "CCI-000130"
  definition String  @db.Text
  control    Control? @relation(fields: [controlId], references: [id])
  controlId  String?

  findings Finding[] @relation("FindingCci")

  @@index([controlId])
}

// Per-system implementation status of a control (the SSP layer).
enum ControlStatus {
  NOT_IMPLEMENTED
  PLANNED
  IMPLEMENTED
  PARTIALLY_IMPLEMENTED
  INHERITED
  NOT_APPLICABLE
}

model SystemControl {
  id        String        @id @default(cuid())
  system    System        @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId  String
  control   Control       @relation(fields: [controlId], references: [id])
  controlId String
  status    ControlStatus @default(NOT_IMPLEMENTED)
  narrative String?       @db.Text // implementation statement / SSP narrative
  inheritedFrom String?
  evidence  Evidence[]

  updatedAt DateTime @updatedAt

  @@unique([systemId, controlId])
  @@index([systemId])
}

// ---------------------------------------------------------------------------
// Scan imports & findings
// ---------------------------------------------------------------------------

enum ScanType {
  ACAS_NESSUS // Tenable/ACAS .nessus XML
  STIG_CKL // DISA STIG Viewer .ckl (XML)
  STIG_CKLB // DISA STIG Viewer .cklb (JSON)
  SCAP // SCAP results
}

model ScanImport {
  id         String   @id @default(cuid())
  type       ScanType
  filename   String
  system     System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId   String
  importedBy User     @relation(fields: [importedById], references: [id])
  importedById String
  importedAt DateTime @default(now())

  // Summary counts captured at import time
  totalFindings  Int @default(0)
  openFindings   Int @default(0)
  newFindings    Int @default(0)

  findings Finding[]

  @@index([systemId])
}

enum FindingSource {
  ACAS
  STIG
  SCAP
  MANUAL
}

// Point-in-time open-finding posture for a system — appended on each scan
// import (and optionally on a schedule) to build continuous-monitoring trends.
model PostureSnapshot {
  id        String   @id @default(cuid())
  system    System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId  String
  takenAt   DateTime @default(now())
  scanImportId String? // the import that triggered this snapshot, if any

  openCritical Int @default(0)
  openHigh     Int @default(0)
  openMedium   Int @default(0)
  openLow      Int @default(0)
  totalOpen    Int @default(0)
  // Cumulative closure tracking for burndown
  closedTotal  Int @default(0)

  @@index([systemId, takenAt])
}

// Normalized severity across ACAS (CVSS/plugin) and STIG (CAT) sources.
enum Severity {
  CRITICAL // CAT I-equivalent critical
  HIGH // CAT I
  MEDIUM // CAT II
  LOW // CAT III
  INFO
}

enum FindingStatus {
  OPEN
  NOT_A_FINDING
  NOT_APPLICABLE
  NOT_REVIEWED
  CLOSED // remediated & verified
}

model Finding {
  id     String        @id @default(cuid())
  source FindingSource
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId String
  asset    Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  assetId  String?
  scanImport ScanImport? @relation(fields: [scanImportId], references: [id], onDelete: SetNull)
  scanImportId String?

  // Stable identity for de-duplication across scans:
  //  - ACAS: plugin id
  //  - STIG: rule id (SV-...) / Group id (V-...)
  ruleId      String // e.g. "SV-230221r627750_rule" or "19506" (plugin)
  groupId     String? // e.g. "V-230221"
  stigId      String? // e.g. "RHEL-08-010010"

  title       String
  description String?  @db.Text
  severity    Severity
  status      FindingStatus @default(OPEN)

  // Remediation guidance from the source
  checkText   String? @db.Text
  fixText     String? @db.Text
  comments    String? @db.Text // analyst/engineer finding details

  // ACAS-specific
  pluginId    String?
  cve         String?

  // Assignment & collaboration
  assignee   User?   @relation("FindingAssignee", fields: [assigneeId], references: [id])
  assigneeId String?

  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  // Set when a finding stops appearing in scans (auto-closed by rescan) or is
  // manually closed — drives burndown and aging metrics.
  closedAt          DateTime?
  resolvedByRescan  Boolean   @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ccis     Cci[]            @relation("FindingCci")
  controls FindingControl[]
  poam     Poam?            @relation(fields: [poamId], references: [id], onDelete: SetNull)
  poamId   String?
  comments_rel Comment[]
  deviations   Deviation[]

  @@unique([systemId, ruleId, assetId])
  @@index([systemId, status])
  @@index([severity])
}

// Many-to-many Finding <-> Control (derived via CCI mapping).
model FindingControl {
  finding   Finding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  findingId String
  control   Control @relation(fields: [controlId], references: [id])
  controlId String

  @@id([findingId, controlId])
  @@index([controlId])
}

// ---------------------------------------------------------------------------
// POA&Ms (Plan of Action & Milestones)
// ---------------------------------------------------------------------------

enum PoamStatus {
  DRAFT
  OPEN
  ONGOING
  RISK_ACCEPTED
  COMPLETED
  CLOSED
}

model Poam {
  id       String     @id @default(cuid())
  system   System     @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId String
  // Sequential per-system identifier shown to users (e.g. POAM-0001)
  number   Int

  weakness        String   @db.Text
  sourceIdentifier String? // where the weakness was identified (scan, assessment)
  severity        Severity
  status          PoamStatus @default(OPEN)
  riskRating      ImpactLevel @default(MODERATE)

  // Residual risk after mitigations
  residualRisk    ImpactLevel?

  recommendation  String?  @db.Text
  resourcesRequired String? @db.Text

  owner   User?   @relation("PoamOwner", fields: [ownerId], references: [id])
  ownerId String?

  detectionDate         DateTime  @default(now())
  scheduledCompletion   DateTime?
  actualCompletion      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  findings   Finding[]
  milestones Milestone[]
  controls   PoamControl[]
  mitigations MitigationStatement[] @relation("PoamMitigation")
  comments    Comment[]
  riskAcceptance RiskAcceptance?

  @@unique([systemId, number])
  @@index([systemId, status])
}

// Formal risk acceptance / waiver for a POA&M, recorded on behalf of the
// Authorizing Official. One per POA&M; setting it moves the POA&M to
// RISK_ACCEPTED and records rationale, residual risk, and a review date.
model RiskAcceptance {
  id                  String      @id @default(cuid())
  poam                Poam        @relation(fields: [poamId], references: [id], onDelete: Cascade)
  poamId              String      @unique
  acceptedBy          User        @relation(fields: [acceptedById], references: [id])
  acceptedById        String
  authorizingOfficial String // AO name who approved the acceptance
  rationale           String      @db.Text
  residualRisk        ImpactLevel
  acceptedAt          DateTime    @default(now())
  reviewBy            DateTime? // date the acceptance must be re-reviewed

  @@index([reviewBy])
}

// ---------------------------------------------------------------------------
// Finding deviations (false positive / operational requirement)
// ---------------------------------------------------------------------------

enum DeviationType {
  FALSE_POSITIVE // scanner result is incorrect for this asset
  OPERATIONAL_REQUIREMENT // requirement cannot apply (documented justification)
}

enum DeviationStatus {
  PENDING
  APPROVED
  REJECTED
}

// A formal, reviewed request to deviate from a scan finding. Approval by a
// senior role (risk:accept capability) updates the finding status:
// FALSE_POSITIVE -> NOT_A_FINDING, OPERATIONAL_REQUIREMENT -> NOT_APPLICABLE.
// Risk-with-remediation-later stays in the POA&M risk-acceptance flow.
model Deviation {
  id        String          @id @default(cuid())
  finding   Finding         @relation(fields: [findingId], references: [id], onDelete: Cascade)
  findingId String
  type      DeviationType
  status    DeviationStatus @default(PENDING)

  justification String @db.Text
  evidence      String? @db.Text // e.g. version output, config excerpt

  requestedBy   User   @relation("DeviationRequestor", fields: [requestedById], references: [id])
  requestedById String
  requestedAt   DateTime @default(now())

  decidedBy   User?     @relation("DeviationDecider", fields: [decidedById], references: [id])
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?  @db.Text

  @@index([findingId])
  @@index([status])
}

model Milestone {
  id          String   @id @default(cuid())
  poam        Poam     @relation(fields: [poamId], references: [id], onDelete: Cascade)
  poamId      String
  description String
  dueDate     DateTime?
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([poamId])
}

model PoamControl {
  poam      Poam    @relation(fields: [poamId], references: [id], onDelete: Cascade)
  poamId    String
  control   Control @relation(fields: [controlId], references: [id])
  controlId String

  @@id([poamId, controlId])
}

// ---------------------------------------------------------------------------
// Mitigation statement library (reusable across systems & POA&Ms)
// ---------------------------------------------------------------------------

model MitigationStatement {
  id       String  @id @default(cuid())
  title    String
  body     String  @db.Text
  // Tag for reuse/searchability (e.g. "Apache", "RHEL8", "encryption")
  tags     String[]
  approved Boolean @default(false)

  author   User?   @relation(fields: [authorId], references: [id])
  authorId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  controlLinks MitigationControl[]
  poams        Poam[]              @relation("PoamMitigation")

  @@index([approved])
}

model MitigationControl {
  mitigation   MitigationStatement @relation(fields: [mitigationId], references: [id], onDelete: Cascade)
  mitigationId String
  control      Control             @relation(fields: [controlId], references: [id])
  controlId    String

  @@id([mitigationId, controlId])
}

// ---------------------------------------------------------------------------
// Collaboration: comments & activity feed
// ---------------------------------------------------------------------------

model Comment {
  id     String @id @default(cuid())
  body   String @db.Text
  author User   @relation(fields: [authorId], references: [id])
  authorId String

  finding   Finding? @relation(fields: [findingId], references: [id], onDelete: Cascade)
  findingId String?
  poam      Poam?    @relation(fields: [poamId], references: [id], onDelete: Cascade)
  poamId    String?

  createdAt DateTime @default(now())

  @@index([findingId])
  @@index([poamId])
}

model Activity {
  id        String   @id @default(cuid())
  actor     User?    @relation(fields: [actorId], references: [id])
  actorId   String?
  verb      String // e.g. "imported", "created", "closed"
  entity    String // e.g. "Finding", "Poam", "System"
  entityId  String?
  summary   String
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// System interconnections (ISA/MOU/MOA) & control evidence
// ---------------------------------------------------------------------------

enum AgreementType {
  ISA // Interconnection Security Agreement
  MOU // Memorandum of Understanding
  MOA // Memorandum of Agreement
  SLA // Service Level Agreement
  OTHER
}

enum InterconnectionStatus {
  PLANNED
  PENDING_APPROVAL
  ACTIVE
  EXPIRED
  TERMINATED
}

// A documented connection between this system and an external system —
// the SSP interconnection table / CA-3 information exchange record.
model Interconnection {
  id       String @id @default(cuid())
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId String

  remoteName    String // external system / organization name
  remoteOwner   String? // owning organization / POC
  connectionType String // e.g. "IPsec VPN", "Dedicated circuit", "HTTPS API"
  direction     FlowDirection @default(BIDIRECTIONAL)
  dataDescription String? @db.Text
  classification  String? // e.g. "CUI", "Unclassified"

  agreementType AgreementType         @default(ISA)
  status        InterconnectionStatus @default(PENDING_APPROVAL)
  agreementDate DateTime?
  expiresAt     DateTime?
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([systemId])
  @@index([expiresAt])
}

// Evidence artifact backing a control implementation (assessment proof):
// config excerpts, screenshots, policy docs. Bytes live in Postgres so the
// whole ATO package stays inside the database (air-gap friendly).
model Evidence {
  id              String        @id @default(cuid())
  systemControl   SystemControl @relation(fields: [systemControlId], references: [id], onDelete: Cascade)
  systemControlId String

  description String
  filename    String?
  contentType String?
  size        Int     @default(0)
  sha256      String?
  data        Bytes?

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String
  uploadedAt   DateTime @default(now())

  @@index([systemControlId])
}

// ---------------------------------------------------------------------------
// Document library (versioned files with a review workflow)
// ---------------------------------------------------------------------------

enum DocumentCategory {
  POLICY
  PLAN // SSP, IRP, contingency plan...
  DIAGRAM
  AUTHORIZATION // ATO letters, memos
  ASSESSMENT // SARs, scan reports
  AGREEMENT // ISAs, MOUs
  OTHER
}

enum DocumentStatus {
  DRAFT
  READY_FOR_REVIEW
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
  ARCHIVED
}

// A tracked document for a system's ATO package. Content lives in versions;
// the document row carries title/category and the review state.
model SystemDocument {
  id       String @id @default(cuid())
  system   System @relation(fields: [systemId], references: [id], onDelete: Cascade)
  systemId String

  title    String
  category DocumentCategory @default(OTHER)
  status   DocumentStatus   @default(DRAFT)

  createdBy   User   @relation("DocumentCreator", fields: [createdById], references: [id])
  createdById String
  reviewer    User?  @relation("DocumentReviewer", fields: [reviewerId], references: [id])
  reviewerId  String?

  // Policy lifecycle: controls this document satisfies (e.g. ["AC-1"]) and
  // the periodic re-review cadence. nextReviewDue is set on approval.
  controls             String[] @default([])
  reviewFrequencyMonths Int?
  nextReviewDue        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions DocumentVersion[]
  events   DocumentEvent[]

  @@index([systemId, status])
}

// Immutable file version: who uploaded it, when, and what changed.
model DocumentVersion {
  id         String         @id @default(cuid())
  document   SystemDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String
  versionNo  Int

  filename    String
  contentType String?
  size        Int
  sha256      String
  data        Bytes

  changeNote String @db.Text // what was modified in this version (required)

  uploadedBy   User   @relation(fields: [uploadedById], references: [id])
  uploadedById String
  uploadedAt   DateTime @default(now())

  @@unique([documentId, versionNo])
  @@index([documentId])
}

// Per-document timeline: status transitions and review comments.
model DocumentEvent {
  id         String         @id @default(cuid())
  document   SystemDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String

  actor   User   @relation(fields: [actorId], references: [id])
  actorId String

  fromStatus DocumentStatus?
  toStatus   DocumentStatus?
  note       String? @db.Text

  createdAt DateTime @default(now())

  @@index([documentId])
}
