      </ReportItem>
      <ReportItem port="443" svc_name="https" protocol="tcp" severity="3" pluginID="200456" pluginName="SSL Certificate Signed Using Weak Hashing Algorithm" pluginFamily="General">
        <risk_factor>High</risk_factor>
        <synopsis>The SSL certificate has been signed using a weak hash algorithm.</synopsis>
        <description>The remote service uses an SSL certificate signed with SHA-1, which is cryptographically weak.</description>
        <solution>Reissue the certificate using SHA-256 or stronger.</solution>
      </ReportItem>
      <ReportItem port="22" svc_name="ssh" protocol="tcp" severity="2" pluginID="210789" pluginName="SSH Weak Key Exchange Algorithms Enabled" pluginFamily="Misc.">
        <risk_factor>Medium</risk_factor>
        <synopsis>The SSH server allows weak key exchange algorithms.</synopsis>
        <description>The remote SSH server is configured to allow weak key exchange algorithms.</description>
        <solution>Disable weak KEX algorithms in sshd_config.</solution>
      </ReportItem>
    </ReportHost>
