      <ReportItem port="0" svc_name="general" protocol="tcp" severity="4" pluginID="190123" pluginName="RHEL 8 : kernel security update (Critical)" pluginFamily="Red Hat Local Security Checks">
        <risk_factor>Critical</risk_factor>
        <synopsis>The remote Red Hat host is missing a critical kernel security update.</synopsis>
        <description>A kernel flaw allows local privilege escalation (CVE-2024-12345). An attacker could gain root.</description>
        <solution>Update the kernel package to the latest version and reboot.</solution>
